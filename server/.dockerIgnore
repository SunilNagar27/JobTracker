# Ignore node_modules folder to prevent copying it into the Docker image
node_modules/

# Ignore build folder if you're building the app locally, and it's not needed in the Docker container
build/

# Ignore .git directory to avoid copying the git history
.git/

# Ignore Docker-related files (optional)
.dockerignore
Dockerfile
docker-compose.yml

# Ignore local development environment files like .env files (if not required for Docker)
*.env
*.env.local

# Ignore logs, temp, or other unnecessary files
*.log
*.tmp
*.swp

# Ignore IDE/editor specific files
.vscode/
.idea/

# Ignore other temporary or unnecessary files
*.DS_Store
*.bak
